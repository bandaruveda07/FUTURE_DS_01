    "# ============================================================\n",
    "# FUTURE INTERNS - TASK 1\n",
    "# Business Sales Performance Analytics\n",
    "# Dataset: Online Retail Dataset\n",
    "# ============================================================\n",
    "\n",
    "# -----------------------------\n",
    "# 1. IMPORT LIBRARIES\n",
    "# -----------------------------\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# -----------------------------\n",
    "# 2. LOAD DATASET\n",
    "# -----------------------------\n",
    "# Replace with your dataset filename\n",
    "df = pd.read_csv(r\"C:\\Users\\HP\\Downloads\\archive (1)\\online_retail.csv\", encoding='latin1')\n",
    "\n",
    "# -----------------------------\n",
    "# 3. DISPLAY BASIC INFO\n",
    "# -----------------------------\n",
    "print(\"First 5 Rows:\")\n",
    "print(df.head())\n",
    "\n",
    "print(\"\\nDataset Shape:\")\n",
    "print(df.shape)\n",
    "\n",
    "print(\"\\nDataset Info:\")\n",
    "print(df.info())\n",
    "\n",
    "print(\"\\nMissing Values:\")\n",
    "print(df.isnull().sum())\n",
    "\n",
    "# -----------------------------\n",
    "# 4. DATA CLEANING\n",
    "# -----------------------------\n",
    "\n",
    "# Remove missing CustomerID\n",
    "df = df.dropna(subset=['CustomerID'])\n",
    "\n",
    "# Remove cancelled invoices\n",
    "df = df[~df['InvoiceNo'].astype(str).str.startswith('C')]\n",
    "\n",
    "# Remove negative quantities\n",
    "df = df[df['Quantity'] > 0]\n",
    "\n",
    "# Remove negative prices\n",
    "df = df[df['UnitPrice'] > 0]\n",
    "\n",
    "# Remove duplicates\n",
    "df = df.drop_duplicates()\n",
    "\n",
    "print(\"\\nCleaned Dataset Shape:\")\n",
    "print(df.shape)\n",
    "\n",
    "# -----------------------------\n",
    "# 5. FEATURE ENGINEERING\n",
    "# -----------------------------\n",
    "\n",
    "# Convert InvoiceDate to datetime\n",
    "df['InvoiceDate'] = pd.to_datetime(df['InvoiceDate'])\n",
    "\n",
    "# Create Revenue column\n",
    "df['Revenue'] = df['Quantity'] * df['UnitPrice']\n",
    "\n",
    "# Extract Month and Year\n",
    "df['Month'] = df['InvoiceDate'].dt.month\n",
    "df['YearMonth'] = df['InvoiceDate'].dt.to_period('M')\n",
    "\n",
    "# -----------------------------\n",
    "# 6. KPI ANALYSIS\n",
    "# -----------------------------\n",
    "\n",
    "total_revenue = df['Revenue'].sum()\n",
    "total_orders = df['InvoiceNo'].nunique()\n",
    "total_customers = df['CustomerID'].nunique()\n",
    "top_country = df.groupby('Country')['Revenue'].sum().idxmax()\n",
    "\n",
    "print(\"\\n========== KPI RESULTS ==========\")\n",
    "print(f\"Total Revenue: ${total_revenue:,.2f}\")\n",
    "print(f\"Total Orders: {total_orders}\")\n",
    "print(f\"Total Customers: {total_customers}\")\n",
    "print(f\"Top Country: {top_country}\")\n",
    "\n",
    "# -----------------------------\n",
    "# 7. MONTHLY REVENUE TREND\n",
    "# -----------------------------\n",
    "\n",
    "monthly_sales = df.groupby('YearMonth')['Revenue'].sum()\n",
    "\n",
    "plt.figure(figsize=(12,6))\n",
    "monthly_sales.plot(kind='line', marker='o')\n",
    "plt.title('Monthly Revenue Trend')\n",
    "plt.xlabel('Month')\n",
    "plt.ylabel('Revenue')\n",
    "plt.grid(True)\n",
    "plt.xticks(rotation=45)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# -----------------------------\n",
    "# 8. TOP 10 SELLING PRODUCTS\n",
    "# -----------------------------\n",
    "\n",
    "top_products = df.groupby('Description')['Quantity'].sum().sort_values(ascending=False).head(10)\n",
    "\n",
    "plt.figure(figsize=(12,6))\n",
    "top_products.sort_values().plot(kind='barh')\n",
    "plt.title('Top 10 Selling Products')\n",
    "plt.xlabel('Quantity Sold')\n",
    "plt.ylabel('Product')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(\"\\nTop 10 Products:\")\n",
    "print(top_products)\n",
    "\n",
    "# -----------------------------\n",
    "# 9. TOP 10 REVENUE GENERATING PRODUCTS\n",
    "# -----------------------------\n",
    "\n",
    "top_revenue_products = df.groupby('Description')['Revenue'].sum().sort_values(ascending=False).head(10)\n",
    "\n",
    "plt.figure(figsize=(12,6))\n",
    "top_revenue_products.sort_values().plot(kind='barh')\n",
    "plt.title('Top 10 Revenue Generating Products')\n",
    "plt.xlabel('Revenue')\n",
    "plt.ylabel('Product')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(\"\\nTop Revenue Products:\")\n",
    "print(top_revenue_products)\n",
    "\n",
    "# -----------------------------\n",
    "# 10. COUNTRY-WISE SALES\n",
    "# -----------------------------\n",
    "\n",
    "country_sales = df.groupby('Country')['Revenue'].sum().sort_values(ascending=False).head(10)\n",
    "\n",
    "plt.figure(figsize=(12,6))\n",
    "country_sales.plot(kind='bar')\n",
    "plt.title('Top 10 Countries by Revenue')\n",
    "plt.xlabel('Country')\n",
    "plt.ylabel('Revenue')\n",
    "plt.xticks(rotation=45)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(\"\\nTop Countries by Revenue:\")\n",
    "print(country_sales)\n",
    "\n",
    "# -----------------------------\n",
    "# 11. CUSTOMER ANALYSIS\n",
    "# -----------------------------\n",
    "\n",
    "customer_revenue = df.groupby('CustomerID')['Revenue'].sum().sort_values(ascending=False).head(10)\n",
    "\n",
    "plt.figure(figsize=(12,6))\n",
    "customer_revenue.plot(kind='bar')\n",
    "plt.title('Top 10 High-Value Customers')\n",
    "plt.xlabel('Customer ID')\n",
    "plt.ylabel('Revenue')\n",
    "plt.xticks(rotation=45)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(\"\\nTop High Value Customers:\")\n",
    "print(customer_revenue)\n",
    "\n",
    "# -----------------------------\n",
    "# 12. MOST FREQUENTLY PURCHASED PRODUCTS\n",
    "# -----------------------------\n",
    "\n",
    "frequent_products = df.groupby('Description')['InvoiceNo'].count().sort_values(ascending=False).head(10)\n",
    "\n",
    "plt.figure(figsize=(12,6))\n",
    "frequent_products.sort_values().plot(kind='barh')\n",
    "plt.title('Most Frequently Purchased Products')\n",
    "plt.xlabel('Purchase Frequency')\n",
    "plt.ylabel('Product')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# -----------------------------\n",
    "# 13. SALES DISTRIBUTION\n",
    "# -----------------------------\n",
    "\n",
    "plt.figure(figsize=(10,6))\n",
    "df['Revenue'].hist(bins=50)\n",
    "plt.title('Revenue Distribution')\n",
    "plt.xlabel('Revenue')\n",
    "plt.ylabel('Frequency')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# -----------------------------\n",
    "# 14. SAVE CLEANED DATA\n",
    "# -----------------------------\n",
    "\n",
    "df.to_csv(\"Cleaned_Online_Retail.csv\", index=False)\n",
    "\n",
    "print(\"\\nCleaned dataset saved successfully!\")\n",
    "\n",
    "# -----------------------------\n",
    "# 15. BUSINESS INSIGHTS\n",
    "# -----------------------------\n",
    "\n",
    "print(\"\\n========== BUSINESS INSIGHTS ==========\")\n",
    "\n",
    "print(\"\"\"\n",
    "1. Revenue trends show seasonal fluctuations in sales.\n",
    "\n",
    "2. A small number of products contribute significantly to total revenue.\n",
    "\n",
    "3. The United Kingdom dominates overall sales performance.\n",
    "\n",
    "4. Repeat customers generate substantial business revenue.\n",
    "\n",
    "5. Some products are purchased frequently but generate lower revenue.\n",
    "\n",
    "6. High-value customers should be targeted with loyalty programs.\n",
    "\"\"\")\n",
    "\n",
    "# -----------------------------\n",
    "# 16. RECOMMENDATIONS\n",
    "# -----------------------------\n",
    "\n",
    "print(\"\\n========== RECOMMENDATIONS ==========\")\n",
    "\n",
    "print(\"\"\"\n",
    "1. Increase marketing for top-performing products.\n",
    "\n",
    "2. Focus customer retention strategies on high-value customers.\n",
    "\n",
    "3. Optimize inventory during peak sales months.\n",
    "\n",
    "4. Expand sales efforts in high-performing regions.\n",
    "\n",
    "5. Bundle low-performing products with best sellers.\n",
    "\"\"\")\n",
    "\n",
    "print(\"\\nTask 1 Completed Successfully!\")"
   ]
